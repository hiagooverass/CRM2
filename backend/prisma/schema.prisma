generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model billing {
  id         String    @id @default(uuid())
  clientId   String
  contractId String?
  amount     Float
  dueDate    DateTime
  paidDate   DateTime?
  status     String    @default("PENDENTE")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  userId     String?
  client     client    @relation(fields: [clientId], references: [id], map: "Billing_clientId_fkey")
  contract   contract? @relation(fields: [contractId], references: [id], map: "Billing_contractId_fkey")
  user       user?     @relation(fields: [userId], references: [id], map: "Billing_userId_fkey")

  @@index([clientId], map: "Billing_clientId_fkey")
  @@index([contractId], map: "Billing_contractId_fkey")
  @@index([userId], map: "Billing_userId_fkey")
}

model client {
  id             String     @id @default(uuid())
  type           String
  name           String
  document       String     @unique(map: "Client_document_key")
  email          String?
  phone          String?
  address        String?
  birthDate      DateTime?
  tradingName    String?
  legalNature    String?
  foundationDate DateTime?
  score          Int        @default(0)
  classification String     @default("BAIXO")
  scoreReasons   String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  userId         String?
  billing        billing[]
  user           user?      @relation(fields: [userId], references: [id], map: "Client_userId_fkey")
  contract       contract[]
  documents      document[]

  @@index([userId], map: "Client_userId_fkey")
}

model contract {
  id        String    @id @default(uuid())
  clientId  String
  value     Float
  status    String    @default("PENDENTE")
  startDate DateTime  @default(now())
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userId    String?
  billing   billing[]
  client    client    @relation(fields: [clientId], references: [id], map: "Contract_clientId_fkey")
  user      user?     @relation(fields: [userId], references: [id], map: "Contract_userId_fkey")

  @@index([clientId], map: "Contract_clientId_fkey")
  @@index([userId], map: "Contract_userId_fkey")
}

model document {
  id        String   @id @default(uuid())
  clientId  String
  type      String
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client    client   @relation(fields: [clientId], references: [id], map: "Document_clientId_fkey")

  @@index([clientId], map: "Document_clientId_fkey")
}

model log {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  module    String
  details   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      user?    @relation(fields: [userId], references: [id], map: "Log_userId_fkey")

  @@index([userId], map: "Log_userId_fkey")
}

model user {
  id        String     @id @default(uuid())
  email     String     @unique(map: "User_email_key")
  password  String
  name      String
  role      String     @default("USER")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  billing   billing[]
  client    client[]
  contract  contract[]
  log       log[]
}
